# ═══════════════════════════════════════════════════════════════
#  AI Video Pipeline — environment variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Ollama ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Models: llama3.2:3b | llama3.1:8b | qwen2.5:7b | mistral:7b
OLLAMA_MODEL=llama3.2:3b

# ── Piper TTS ───────────────────────────────────────────────────
PIPER_EXECUTABLE=piper
# Voices: en_US-lessac-medium | en_US-ryan-high | en_GB-alan-medium
PIPER_MODEL=en_US-lessac-medium

# ── MusicGen ────────────────────────────────────────────────────
# Models: facebook/musicgen-small | facebook/musicgen-medium | facebook/musicgen-large
MUSICGEN_MODEL=facebook/musicgen-small
MUSICGEN_DURATION=30

# ── Image generation ─────────────────────────────────────────────
# Backends: sdxl | flux
IMAGE_BACKEND=sdxl
# SDXL model (used when IMAGE_BACKEND=sdxl)
SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# FLUX model (used when IMAGE_BACKEND=flux, requires ~24 GB VRAM)
FLUX_MODEL=black-forest-labs/FLUX.1-schnell
# Output resolution (9:16 vertical for Shorts/Reels)
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1920

# ── Stable Video Diffusion ───────────────────────────────────────
# Set to true only if you have 24+ GB VRAM
SVD_ENABLED=false
SVD_MODEL=stabilityai/stable-video-diffusion-img2vid-xt
SVD_FRAMES=25
SVD_FPS=7

# ── Whisper ──────────────────────────────────────────────────────
# Sizes: tiny | base | small | medium | large
WHISPER_MODEL=base

# ── Video assembly ───────────────────────────────────────────────
VIDEO_FPS=30
VIDEO_DURATION=60
SCENE_DURATION=5.0

# ── YouTube Data API ─────────────────────────────────────────────
# Download client_secrets.json from Google Cloud Console
YOUTUBE_CLIENT_SECRETS=credentials/youtube_client_secrets.json
YOUTUBE_TOKEN_FILE=credentials/youtube_token.json
YOUTUBE_CATEGORY_ID=22
# Options: private | unlisted | public
YOUTUBE_PRIVACY=private

# ── Instagram / Meta Graph API ───────────────────────────────────
# Obtain from https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
META_API_VERSION=v21.0
